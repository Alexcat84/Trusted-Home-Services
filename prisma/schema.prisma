generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

model Submission {
  id           String   @id @default(cuid())
  type         String   // "quote" | "realtor" | "partner" | "franchise"
  name         String
  email        String?
  phone        String?
  message      String?
  work         String?
  areas        String?
  propertyType String?
  size         String?
  status       String?  @default("new") // new | contacted | offer_sent | ...
  createdAt    DateTime @default(now())
}

model PushSubscription {
  id           String   @id @default(cuid())
  endpoint     String   @unique
  keysP256dh   String
  keysAuth     String
  userAgent    String?
  createdAt    DateTime @default(now())
}
