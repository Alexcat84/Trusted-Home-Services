# ---- Backend (Vercel env) ----
# Panel admin (/#admin): login con usuario y contraseña. ADMIN_SECRET firma el JWT.
# ADMIN_USERNAME=   (usuario para entrar al panel)
# ADMIN_PASSWORD=   (contraseña del admin)
# ADMIN_SECRET=     (clave larga para firmar/verificar JWT; no la compartas)

# ---- Database (Prisma + Postgres) ----
# Vercel Postgres inyecta automáticamente POSTGRES_URL (pooled) y POSTGRES_URL_NON_POOLING (directa).
# Neon/Supabase: usa DATABASE_URL como pooled y DIRECT_URL como directa; en Vercel puedes mapearlas a los nombres de arriba.
# En local sin pooler, puedes usar la misma URL en ambas variables.
# POSTGRES_URL=postgresql://...              (runtime / serverless — con pooler)
# POSTGRES_URL_NON_POOLING=postgresql://...  (migraciones y db push — conexión directa)
# Tras cambios de schema: npx prisma db push

# ---- Sin DB: usar Vercel KV (opcional). Create KV in Vercel Storage, connect to project ----
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# ---- Email: aviso por cada envío de formulario ----
# RESEND_API_KEY=   (https://resend.com/api-keys)
# ADMIN_EMAIL=      (tu correo)
# NOTIFY_FROM_EMAIL=   (opcional; ej. "Trusted Home <noreply@tudominio.com>")

# ---- SMS: aviso por Twilio (opcional) ----
# Cuenta en https://www.twilio.com; compra un número con capacidad SMS.
# TWILIO_ACCOUNT_SID=   (Dashboard)
# TWILIO_AUTH_TOKEN=    (Dashboard)
# TWILIO_PHONE_NUMBER=  (ej. +16135551234, el número que compraste)
# ADMIN_PHONE=          (ej. +16135559999, tu móvil donde recibir los SMS)

# ---- Push: notificaciones en el admin PWA (opcional; VAPID) ----
# Solo si quieres push: npx web-push generate-vapid-keys y añade:
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_MAILTO=mailto:info@tudominio.com   (opcional)

# ---- Notify.Events: un solo servicio para email, SMS, push, Telegram, etc. (opcional, plan gratis limitado) ----
# Crea un canal en https://notify.events, añade la fuente "Incoming Webhook v2" o "Node.js" y copia el token de la fuente.
# NOTIFY_EVENTS_SOURCE_TOKEN=   (token de la fuente; o la URL completa del webhook si te la dan)

# ---- Formspree fallback si /api/submit falla (opcional) ----
# VITE_FORMSPREE_REALTOR=
# VITE_FORMSPREE_QUOTE=
